---
const { pathname } = Astro.url;
const navItems = [
  { href: '/', label: '文章', page: 'home' },
  { href: '/archive', label: '归档', page: 'archive' },
  { href: '/about', label: '关于', page: 'about' },
];
---
---
<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="logo">howdo.icu</a>
    <nav class="nav" id="nav">
      {navItems.map(item => (
        <a href={item.href} class={pathname === item.href ? 'active' : ''}>{item.label}</a>
      ))}
      <div class="nav-divider"></div>
      <a href="/#newsletter" class="subscribe-link">订阅</a>
    </nav>
    <button class="menu-toggle" onclick="document.getElementById('nav').classList.toggle('open')">☰</button>
  </div>
</header>
