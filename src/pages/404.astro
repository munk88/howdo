---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — howdo.icu" description="页面不存在">
  <section class="hero">
    <div class="hero-inner">
      <span class="kicker">404 NOT FOUND</span>
      <h1>这一页<br />还没被写下来。</h1>
      <p class="hero-sub">你访问的页面不存在，或者还没被写下来。不如回首页看看？</p>
      <a href="/" class="read-more" style="margin-top: 16px; display: inline-block;">← 返回首页</a>
    </div>
  </section>
</BaseLayout>
